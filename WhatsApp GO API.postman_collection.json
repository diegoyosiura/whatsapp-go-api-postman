			"event": [
				{
					"listen": "prerequest",
					"script": {
						"type": "text/javascript",
						"exec": [
							"// === AUTO-LOGIN SYSADMIN ===",
							"// Se sysadmin_access_token estiver vazio e nao for o proprio login,",
							"// faz login automatico com credenciais sysadmin do environment.",
							"",
							"const currentUrl = pm.request.url.toString();",
							"const isLoginRequest = currentUrl.includes('/iam/login');",
							"",
							"if (!isLoginRequest) {",
							"    const token = pm.environment.get('sysadmin_access_token');",
							"    if (!token || token.trim() === '') {",
							"        const baseUrl = pm.environment.get('base_url');",
							"        const apiVersion = pm.environment.get('api_version');",
							"        const email = pm.environment.get('sysadmin_email');",
							"        const password = pm.environment.get('sysadmin_password');",
							"",
							"        if (email && password) {",
							"            pm.sendRequest({",
							"                url: baseUrl + '/' + apiVersion + '/iam/login',",
							"                method: 'POST',",
							"                header: { 'Content-Type': 'application/json' },",
							"                body: {",
							"                    mode: 'raw',",
							"                    raw: JSON.stringify({ email: email, password: password })",
							"                }",
							"            }, function (err, res) {",
							"                if (!err && res.code === 200) {",
							"                    const body = res.json();",
							"                    pm.environment.set('sysadmin_access_token', body.access_token);",
							"                    pm.environment.set('sysadmin_refresh_token', body.refresh_token);",
							"                    console.log('[Auto-Login Sysadmin] Token obtido para ' + email);",
							"                } else {",
							"                    console.warn('[Auto-Login Sysadmin] Falha: ' + (err || res.status));",
							"                }",
							"            });",
							"        } else {",
							"            console.warn('[Auto-Login Sysadmin] sysadmin_email ou sysadmin_password nao configurados no environment');",
							"        }",
							"    }",
							"}"
						]
					}
				}
			],
